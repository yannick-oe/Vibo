{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/manifest.webmanifest",
          "/*.js",
          "/*.css",
          "/favicon.ico",
          "/favicon/favicon.svg",
          "/pwa-icons/**"
        ]
      }
    },
    {
      "name": "media-lazy",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": [
          "/emojis/**",
          "/avatars/**",
          "/fonts/**",
          "/app-icons/**",
          "/logos/**",
          "/sounds/**",
          "/emoji-data.de.json"
        ]
      }
    }
  ]
}
