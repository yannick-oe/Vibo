# Apache config for Vibo served from the subfolder /vibo/browser/.
# Angular SPA fallback: deep links (e.g. /vibo/browser/app/channel/{id})
# and the reset route must resolve to index.html instead of a 404.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /vibo/browser/

  # Serve existing files and directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route everything else to the app shell.
  RewriteRule ^ index.html [L]
</IfModule>
