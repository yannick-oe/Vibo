# Apache config for the netcup shared-hosting deploy (uploaded via FileZilla —
# enable "Force showing hidden files" so this file transfers). Every block is
# wrapped in <IfModule> so a host without the module serves without errors
# instead of failing with a 500.
#
# Caching is declared through BOTH mod_headers (authoritative Cache-Control
# values, incl. immutable) and mod_expires (fallback: emits Expires plus a
# plain Cache-Control max-age) — whichever module the host actually enables
# takes effect. Live verification 2026-07-15 showed nginx-fronted responses
# without any Cache-Control, so the X-Vibo-Htaccess marker below tells apart
# "mod_headers off" from ".htaccess ignored entirely".
#
# Cache policy (single source for both blocks):
# - Hashed build outputs (esbuild 8-char uppercase hash: chunk-XXXXXXXX.js,
#   main-XXXXXXXX.js, styles-XXXXXXXX.css, media/*-XXXXXXXX.*):
#   1 year, immutable — IMMUTABLE_TTL_SECONDS = 31536000.
# - Unhashed statics (fonts/*.woff2 incl. Inter-Variable.woff2, emojis/*.svg,
#   avatars/*, app-icons, logos, favicons): STATIC_ASSET_TTL_SECONDS = 604800
#   (7 days).
# - index.html and emoji-data.de.json: no-cache — a deploy must take effect
#   immediately (ETag/Last-Modified keep 304 revalidation cheap).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^auth-action$ /#/auth/action?%{QUERY_STRING} [NE,R=302,L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_mime.c>
  AddType font/woff2 .woff2
  AddType image/webp .webp
  AddType text/javascript .mjs
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_headers.c>
  # Diagnostic marker on every response: present on the live host means
  # mod_headers processes this file; absent means it does not.
  Header always set X-Vibo-Htaccess "v2"

  # Unhashed static assets: STATIC_ASSET_TTL_SECONDS (7 days). Declared
  # first — the hashed rule below overrides where both match.
  <FilesMatch "\.(woff2|svg|webp|png|jpeg|jpg|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # Hashed build outputs (pattern derived from the real dist: esbuild emits
  # an 8-char uppercase base32 hash, e.g. chunk-BMFZL43B.js): forever.
  <FilesMatch "-[A-Z0-9]{8}\.(js|mjs|css|woff2|svg|webp|png)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # The entry document and the runtime-fetched, unhashed emoji catalogue
  # must always revalidate so a deploy takes effect immediately.
  <FilesMatch "^(index\.html|emoji-data\.de\.json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  # Fallback for hosts without mod_headers: mod_expires emits Expires plus
  # Cache-Control max-age (no immutable — acceptable). Same policy and the
  # same override order as the mod_headers block above.
  ExpiresActive On
  ExpiresDefault "access plus 0 seconds"

  <FilesMatch "\.(woff2|svg|webp|png|jpeg|jpg|ico)$">
    ExpiresDefault "access plus 7 days"
  </FilesMatch>

  <FilesMatch "-[A-Z0-9]{8}\.(js|mjs|css|woff2|svg|webp|png)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  <FilesMatch "^(index\.html|emoji-data\.de\.json)$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>
</IfModule>
