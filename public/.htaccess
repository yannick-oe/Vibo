# Apache config for the netcup shared-hosting deploy (uploaded via FileZilla —
# enable "Force showing hidden files" so this file transfers). Every block is
# wrapped in <IfModule> so a host without the module serves without errors
# instead of failing with a 500.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^auth-action$ /#/auth/action?%{QUERY_STRING} [NE,R=302,L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_mime.c>
  AddType font/woff2 .woff2
  AddType image/webp .webp
  AddType text/javascript .mjs
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_headers.c>
  # Unhashed static assets (fonts, icons, emojis, avatars, logos): cache a
  # week. Declared first — the hashed rule below overrides where both match.
  <FilesMatch "\.(woff2|svg|webp|png|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # Angular build outputs carry a content hash in the filename (main-XXXXXXXX.js,
  # chunk-XXXXXXXX.js, styles-XXXXXXXX.css, media/*): safe to cache forever.
  <FilesMatch "-[A-Za-z0-9]{8}\.(js|mjs|css|woff2|svg|webp|png)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Runtime-fetched catalogue data without a hash: revalidate daily.
  <FilesMatch "^emoji-data\..*\.json$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # The entry document must always revalidate so a deploy takes effect
  # immediately (it references the current hashed bundles).
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
