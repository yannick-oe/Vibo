rules_version = '2';

// Vibo production rules. Default deny: anything not explicitly
// allowed below is rejected. Deployed via `firebase deploy --only
// firestore:rules` (see firebase.json); the model is documented in
// CLAUDE.md.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function channelMembers(channelId) {
      return get(/databases/$(database)/documents/channels/$(channelId)).data.memberIds;
    }

    // Post-batch membership: join-on-send writes the message and the
    // membership in one batch, so message creates check the state the
    // batch produces.
    function channelMembersAfter(channelId) {
      return getAfter(/databases/$(database)/documents/channels/$(channelId)).data.memberIds;
    }

    function isChannelMember(channelId) {
      return signedIn() && request.auth.uid in channelMembers(channelId);
    }

    // Message/reply documents are only hard-deleted during the
    // client-side teardown of a channel whose last member leaves.
    function isSoleChannelMember(channelId) {
      return signedIn() && channelMembers(channelId) == [request.auth.uid];
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Optional inline-reply reference ("Antworten"): an exact-shaped snapshot
    // map with string fields, the same id length cap as the notification
    // fields and the previewText cap mirroring REPLY_PREVIEW_MAX. Absent on
    // ordinary messages and on thread replies.
    function validReplyTo() {
      return request.resource.data.replyTo is map
        && request.resource.data.replyTo.keys().hasOnly(['messageId', 'authorUid', 'previewText'])
        && request.resource.data.replyTo.keys().hasAll(['messageId', 'authorUid', 'previewText'])
        && request.resource.data.replyTo.messageId is string
        && request.resource.data.replyTo.messageId.size() >= 1
        && request.resource.data.replyTo.messageId.size() <= 128
        && request.resource.data.replyTo.authorUid is string
        && request.resource.data.replyTo.authorUid.size() >= 1
        && request.resource.data.replyTo.authorUid.size() <= 128
        && request.resource.data.replyTo.previewText is string
        && request.resource.data.replyTo.previewText.size() >= 1
        && request.resource.data.replyTo.previewText.size() <= 150;
    }

    // System messages (currently only the channel-join pill) are authored
    // by the joining user themselves, carry no text and never quote.
    function validSystemShape() {
      return request.resource.data.kind == 'system'
        && request.resource.data.subtype == 'join'
        && request.resource.data.text == ''
        && !('replyTo' in request.resource.data);
    }

    // createdAt is pinned to the server clock (or earlier) so the
    // 15-minute edit window below cannot be extended by future-dating.
    function validMessageCreate() {
      return request.resource.data.authorId == request.auth.uid
        && request.resource.data.createdAt <= request.time
        && (!('replyTo' in request.resource.data) || validReplyTo())
        && (!('kind' in request.resource.data) || validSystemShape());
    }

    function editsOwnTextInWindow() {
      return resource.data.authorId == request.auth.uid
        && !('deletedAt' in resource.data)
        && affectedKeys().hasOnly(['text', 'editedAt'])
        && request.resource.data.editedAt == request.time
        && request.time < resource.data.createdAt + duration.value(15, 'm');
    }

    // "Für alle löschen": the author clears text and reactions and
    // stamps the tombstone; no time limit by design.
    function setsTombstone() {
      return resource.data.authorId == request.auth.uid
        && affectedKeys().hasOnly(['deletedAt', 'deletedBy', 'text', 'reactions'])
        && request.resource.data.deletedAt == request.time
        && request.resource.data.deletedBy == request.auth.uid
        && request.resource.data.text == ''
        && request.resource.data.reactions == {};
    }

    function togglesReactionsOnly() {
      return affectedKeys().hasOnly(['reactions']);
    }

    // Broadcast big reaction: any member/participant stamps the latest event
    // (their own uid, server time) so every viewer replays it once.
    function setsBigReaction() {
      return affectedKeys().hasOnly(['lastBigReaction'])
        && request.resource.data.lastBigReaction.type in ['confetti', 'hearts', 'rocket', 'laugh', 'fire', 'clap', 'tear', 'flash']
        && request.resource.data.lastBigReaction.by == request.auth.uid
        && request.resource.data.lastBigReaction.at == request.time;
    }

    // "Für mich löschen": a user may only append their own uid.
    function appendsSelfToHiddenFor() {
      return affectedKeys().hasOnly(['hiddenFor'])
        && request.resource.data.hiddenFor.hasAll(resource.data.get('hiddenFor', []))
        && request.resource.data.hiddenFor.size() == resource.data.get('hiddenFor', []).size() + 1
        && request.auth.uid in request.resource.data.hiddenFor
        && !(request.auth.uid in resource.data.get('hiddenFor', []));
    }

    // Posting a reply also registers the author as a thread participant
    // (arrayUnion in the same batch): only their own uid may be appended,
    // so the thread-reply notification fan-out list cannot be forged.
    function appendsSelfToParticipantUids() {
      return request.resource.data.participantUids.hasAll(resource.data.get('participantUids', []))
        && request.resource.data.participantUids.size() == resource.data.get('participantUids', []).size() + 1
        && request.auth.uid in request.resource.data.participantUids
        && !(request.auth.uid in resource.data.get('participantUids', []));
    }

    // Reply authors denormalize the thread preview onto the parent
    // message in the same batch as the reply create; a first-time
    // participant additionally self-appends to participantUids (an
    // arrayUnion no-op for repeat repliers keeps the key unaffected).
    function bumpsReplyCounters() {
      return (affectedKeys().hasOnly(['replyCount', 'lastReplyAt'])
          || (affectedKeys().hasOnly(['replyCount', 'lastReplyAt', 'participantUids'])
            && appendsSelfToParticipantUids()))
        && request.resource.data.replyCount == resource.data.replyCount + 1
        && request.resource.data.lastReplyAt == request.time;
    }

    function allowedMessageUpdate() {
      return editsOwnTextInWindow()
        || setsTombstone()
        || togglesReactionsOnly()
        || appendsSelfToHiddenFor()
        || setsBigReaction();
    }

    // Message pinning: any channel member / DM participant may toggle
    // exactly the boolean pinned flag on TOP-LEVEL messages. Thread
    // replies never get this clause (their update path omits it), and
    // blocked conversations deny it at the call site.
    function togglesPinnedOnly() {
      return affectedKeys().hasOnly(['pinned'])
        && request.resource.data.pinned is bool;
    }

    // Denormalization: the message author stamps the conversation's
    // lastMessageAt/lastMessageAuthorId in the same batch as the message
    // create, so the sidebar detects unread from one small doc.
    function setsLastMessage() {
      return request.resource.data.lastMessageAt == request.time
        && request.resource.data.lastMessageAuthorId == request.auth.uid;
    }

    // Read marker at <conversation>/reads/{uid}: a single lastReadAt pinned
    // to the server clock.
    function readDocValid() {
      return request.resource.data.keys().hasOnly(['lastReadAt'])
        && request.resource.data.lastReadAt == request.time;
    }

    function typingDocValid() {
      return request.resource.data.keys().hasOnly(['uid', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      // The immutable @username (3–20 chars, mirrors USERNAME_MIN/MAX_LENGTH):
      // valid on create and backed by the usernames claim written in the
      // same batch (getAfter), so profile and registry can never diverge.
      function validNewUsername() {
        return request.resource.data.username is string
          && request.resource.data.username.size() >= 3
          && request.resource.data.username.size() <= 20
          && getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.uid == uid;
      }

      // Tolerant immutability: identical on both sides, including the
      // both-absent case of legacy docs before the manual migration.
      function usernameUnchanged() {
        return request.resource.data.get('username', null) == resource.data.get('username', null);
      }

      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid && validNewUsername();
      allow update: if signedIn() && request.auth.uid == uid && usernameUnchanged();
      allow delete: if signedIn() && request.auth.uid == uid;

      // Activity notifications (thread replies, reactions on own messages):
      // the ACTING client fans one document out into each recipient's
      // collection — create-only for foreign users with a strict shape; only
      // the owner reads and clears their feed. No updates by design: rapid
      // reactions stay separate docs and coalesce in the bell UI. The
      // preview is sender-authored (length-capped; same trust level as
      // sending a message).
      function notificationKeysValid() {
        return request.resource.data.keys().hasOnly(['kind', 'actorUid', 'channelId',
            'conversationId', 'messageId', 'inThread', 'emoji', 'preview', 'createdAt'])
          && request.resource.data.keys().hasAll(['kind', 'actorUid', 'messageId',
            'inThread', 'preview', 'createdAt']);
      }

      // The emoji is present exactly for reaction notifications; thread
      // replies and mentions carry no emoji.
      function notificationFieldsValid() {
        return request.resource.data.kind in ['thread-reply', 'reaction', 'mention', 'reply']
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.messageId is string
          && request.resource.data.messageId.size() >= 1
          && request.resource.data.messageId.size() <= 128
          && request.resource.data.inThread is bool
          && request.resource.data.preview is string
          && request.resource.data.preview.size() >= 1
          && request.resource.data.preview.size() <= 120
          && ((request.resource.data.kind == 'reaction') == ('emoji' in request.resource.data))
          && (!('emoji' in request.resource.data)
            || (request.resource.data.emoji is string
              && request.resource.data.emoji.size() >= 1
              && request.resource.data.emoji.size() <= 16))
          && request.resource.data.createdAt == request.time;
      }

      // Exactly one conversation reference. Channel events require the actor
      // AND the recipient to be current members (one cached get); DM events
      // prove both from the deterministic conversation id — no notifications
      // from outside a shared conversation.
      function notificationTargetValid() {
        return (('channelId' in request.resource.data) != ('conversationId' in request.resource.data))
          && (!('channelId' in request.resource.data)
            || (request.resource.data.channelId is string
              && request.resource.data.channelId.size() >= 1
              && request.resource.data.channelId.size() <= 128
              && request.auth.uid in channelMembers(request.resource.data.channelId)
              && uid in channelMembers(request.resource.data.channelId)))
          && (!('conversationId' in request.resource.data)
            || (request.resource.data.conversationId is string
              && request.resource.data.conversationId.size() >= 1
              && request.resource.data.conversationId.size() <= 128
              && request.auth.uid in request.resource.data.conversationId.split('_')
              && uid in request.resource.data.conversationId.split('_')));
      }

      match /notifications/{notificationId} {
        allow read, delete: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn()
          && request.auth.uid != uid
          && notificationKeysValid()
          && notificationFieldsValid()
          && notificationTargetValid();
        allow update: if false;
      }
    }

    // Global registry backing @username uniqueness; doc id = normalized
    // username. Reads are public because the registration form checks
    // availability before an account exists. Claims are immutable (no
    // update/delete); `create` only ever matches a non-existing doc, which
    // is the uniqueness guarantee, and requires the same-batch user doc to
    // carry exactly this handle.
    match /usernames/{name} {
      allow read: if true;
      allow create: if signedIn()
        && name.matches('[a-z0-9]+([._][a-z0-9]+)*')
        && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == name;
      allow update, delete: if false;
    }

    match /channels/{channelId} {
      function memberEditsChannel() {
        return affectedKeys().hasOnly(['name', 'nameLower', 'description', 'memberIds'])
          && request.resource.data.memberIds
            .hasAll(resource.data.memberIds.removeAll([request.auth.uid]));
      }

      function appendsSelfToMembers() {
        return request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.auth.uid in request.resource.data.memberIds
          && !(request.auth.uid in resource.data.memberIds);
      }

      function joinsSelf() {
        return affectedKeys().hasOnly(['memberIds']) && appendsSelfToMembers();
      }

      // Only the channel creator maintains the one-line topic; the length
      // cap mirrors TOPIC_MAX_LENGTH. Kept as its own disjunct so it
      // composes with joinsSelf()/memberEditsChannel() instead of widening
      // them.
      function creatorEditsTopic() {
        return affectedKeys().hasOnly(['topic'])
          && request.auth.uid == resource.data.createdBy
          && request.resource.data.topic is string
          && request.resource.data.topic.size() <= 120;
      }

      // A member denormalizes the last message onto the channel doc.
      function memberSetsLastMessage() {
        return request.auth.uid in resource.data.memberIds
          && affectedKeys().hasOnly(['lastMessageAt', 'lastMessageAuthorId'])
          && setsLastMessage();
      }

      // Join-on-send: the sender joins and denormalizes in one update.
      function joinsAndSetsLastMessage() {
        return affectedKeys().hasOnly(['memberIds', 'lastMessageAt', 'lastMessageAuthorId'])
          && appendsSelfToMembers()
          && setsLastMessage();
      }

      // The permanent default channel is seeded by any signed-in client on
      // first registration. Allowed only at the fixed id 'general' and only
      // with the frozen system-seed shape (no creator, no members), so no
      // arbitrary channel can be created through this branch. The 'general'
      // literal mirrors DEFAULT_CHANNEL_ID in channels.constants.ts.
      function isDefaultChannelSeed() {
        return channelId == 'general'
          && request.resource.data.createdBy == 'system'
          && request.resource.data.isDefault == true
          && request.resource.data.memberIds == []
          && request.resource.data.createdAt <= request.time;
      }

      // Channel names are workspace-public: search, the "#" address
      // list and the duplicate-name check read all channels.
      allow read: if signedIn();

      allow create: if signedIn()
        && ((request.resource.data.createdBy == request.auth.uid
              && request.auth.uid in request.resource.data.memberIds
              && request.resource.data.createdAt <= request.time)
          || isDefaultChannelSeed());

      // Members edit name/description, add members and may remove
      // themselves (leave); the creator maintains the topic; non-members
      // may only add their own uid (join-on-send).
      allow update: if signedIn()
        && ((request.auth.uid in resource.data.memberIds && memberEditsChannel())
          || joinsSelf()
          || creatorEditsTopic()
          || memberSetsLastMessage()
          || joinsAndSetsLastMessage());

      allow delete: if signedIn() && resource.data.memberIds == [request.auth.uid];

      match /messages/{messageId} {
        allow read: if isChannelMember(channelId);
        allow create: if signedIn()
          && request.auth.uid in channelMembersAfter(channelId)
          && validMessageCreate();
        allow update: if isChannelMember(channelId)
          && (allowedMessageUpdate() || bumpsReplyCounters() || togglesPinnedOnly());
        allow delete: if isSoleChannelMember(channelId);

        match /replies/{replyId} {
          allow read: if isChannelMember(channelId);
          allow create: if isChannelMember(channelId) && validMessageCreate();
          allow update: if isChannelMember(channelId) && allowedMessageUpdate();
          allow delete: if isSoleChannelMember(channelId);
        }
      }

      // Co-located per-user read state; readable by any member so the later
      // receipts pass can read all participants' state in one query.
      match /reads/{uid} {
        allow read: if isChannelMember(channelId);
        allow create, update: if signedIn() && request.auth.uid == uid
          && isChannelMember(channelId) && readDocValid();
      }

      // Co-located per-session typing state (doc id = client session, so two
      // windows of the shared guest account never mute each other). The writer's
      // uid rides inside the doc; a member may only write their own uid and may
      // only delete a marker that carries it.
      match /typing/{sessionId} {
        allow read: if isChannelMember(channelId);
        allow create, update: if isChannelMember(channelId) && typingDocValid();
        allow delete: if signedIn() && (resource == null || resource.data.uid == request.auth.uid);
      }
    }

    // Channel invite links at invites/{token}: the unguessable auto-id
    // token IS the access proof, so any signed-in user may resolve one
    // token (get); the management list is provable only against the
    // queried channel's members. The join itself rides the channels
    // joinsSelf() rule — the token is UX/discovery, not a security
    // boundary, since channels are already open-join via join-on-send.
    match /invites/{token} {
      allow get: if signedIn();
      allow list: if signedIn()
        && request.auth.uid in channelMembers(resource.data.channelId);
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['channelId', 'createdBy', 'createdAt', 'expiresAt'])
        && request.resource.data.keys().hasAll(['channelId', 'createdBy', 'createdAt', 'expiresAt'])
        && request.resource.data.channelId is string
        && request.resource.data.channelId.size() >= 1
        && request.resource.data.channelId.size() <= 128
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.auth.uid in channelMembers(request.resource.data.channelId);
      allow update: if false;
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    // Conversation ids are deterministic — both participant uids sorted
    // and joined with "_" (Firebase uids never contain underscores), so
    // participation is validated from the id itself. This also covers
    // the lazy existence check before the first message without
    // granting reads on foreign conversations.
    function isParticipant(conversationId) {
      return signedIn() && request.auth.uid in conversationId.split('_');
    }

    // Whether the conversation pair is currently blocked (the friendship
    // doc shares the conversation id). Blocking freezes the conversation
    // for BOTH participants: no new messages, replies or typing markers.
    function isBlockedConversation(conversationId) {
      return exists(/databases/$(database)/documents/friendships/$(conversationId))
        && get(/databases/$(database)/documents/friendships/$(conversationId)).data.status == 'blocked';
    }

    // Friendship graph. Doc id = both uids sorted and joined with "_" —
    // identical to the conversation-id convention, so a conversation id
    // doubles as its friendship lookup for the DM gating below.
    match /friendships/{friendshipId} {
      function pairFromId() {
        return friendshipId.split('_');
      }

      function isSortedPairId() {
        return pairFromId().size() == 2 && pairFromId()[0] < pairFromId()[1];
      }

      function validFriendshipShape() {
        return request.resource.data.keys()
            .hasOnly(['participants', 'requestedBy', 'status', 'createdAt', 'respondedAt'])
          && request.resource.data.participants == pairFromId()
          && request.resource.data.requestedBy in pairFromId()
          && request.resource.data.createdAt == request.time;
      }

      function isPendingRequest() {
        return request.resource.data.requestedBy == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.respondedAt == null;
      }

      // Demo self-healing: the shared guest account re-creates its accepted
      // founder friendship after every guest reset (see FriendshipService).
      // Restricted to the one exact doc id of that pair. Replace the
      // placeholder with "<guestUid>_<founderUid>" (uids sorted).
      function demoFriendshipId() {
        return 'EtMKQ4MK5Be5xZhXhngptGXr1Ee2_dHsxMektWfWvwbhQWUe9bILbavl1';
      }

      function isDemoSeed() {
        return friendshipId == demoFriendshipId()
          && request.resource.data.status == 'accepted'
          && request.resource.data.respondedAt == request.time;
      }

      // Reads accept either proof of participation: the id (single-doc
      // gets, incl. the seeding existence check on a missing doc) or the
      // stored participants (the `array-contains` list query).
      allow read: if isParticipant(friendshipId)
        || (signedIn() && request.auth.uid in resource.data.participants);

      allow create: if isParticipant(friendshipId)
        && isSortedPairId()
        && validFriendshipShape()
        && (isPendingRequest() || isDemoSeed());

      // Accept: only the recipient flips the pending doc to accepted.
      function acceptsRequest() {
        return request.auth.uid != resource.data.requestedBy
          && resource.data.status == 'pending'
          && affectedKeys().hasOnly(['status', 'respondedAt'])
          && request.resource.data.status == 'accepted'
          && request.resource.data.respondedAt == request.time;
      }

      // Block: either participant flips a pending or accepted doc to
      // 'blocked' naming themselves as the single blocker. An already
      // blocked doc cannot be blocked again (single-blocker model).
      function blocksRelationship() {
        return resource.data.status in ['pending', 'accepted']
          && affectedKeys().hasOnly(['status', 'blockedBy', 'respondedAt'])
          && request.resource.data.status == 'blocked'
          && request.resource.data.blockedBy == request.auth.uid
          && request.resource.data.respondedAt == request.time;
      }

      // Unblock: only the blocker restores the relationship to accepted
      // and removes the blockedBy marker.
      function unblocksRelationship() {
        return resource.data.status == 'blocked'
          && resource.data.blockedBy == request.auth.uid
          && affectedKeys().hasOnly(['status', 'blockedBy', 'respondedAt'])
          && request.resource.data.status == 'accepted'
          && !('blockedBy' in request.resource.data)
          && request.resource.data.respondedAt == request.time;
      }

      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && (acceptsRequest() || blocksRelationship() || unblocksRelationship());

      // Withdraw (requester, pending), decline (recipient, pending) and
      // unfriend (either side, accepted) are all participant deletes; a
      // blocked doc may only be deleted by the blocker, so the blocked
      // user cannot escape the block by deleting the relationship.
      allow delete: if signedIn()
        && request.auth.uid in resource.data.participants
        && (resource.data.status != 'blocked' || resource.data.blockedBy == request.auth.uid);
    }

    match /directMessages/{conversationId} {
      // Reads accept either proof of participation: the id (single-doc
      // gets, incl. the lazy existence check on a missing doc) or the
      // stored participantIds (provable for the global-search list
      // query `where participantIds array-contains uid`).
      // New conversations require an accepted friendship (the friendship
      // doc shares the conversation id); the self conversation is exempt.
      // Existing conversations are grandfathered: reads, message writes
      // and the update below stay id-based and unchanged.
      function isSelfConversation() {
        return conversationId.split('_')[0] == conversationId.split('_')[1];
      }

      function hasAcceptedFriendship() {
        return get(/databases/$(database)/documents/friendships/$(conversationId)).data.status == 'accepted';
      }

      allow read: if isParticipant(conversationId)
        || (signedIn() && request.auth.uid in resource.data.participantIds);
      allow delete: if isParticipant(conversationId);
      allow create: if isParticipant(conversationId)
        && request.resource.data.participantIds == conversationId.split('_')
        && (isSelfConversation() || hasAcceptedFriendship());
      // The only permitted update is the sender denormalizing the last
      // message; participation is proven from the deterministic id.
      allow update: if isParticipant(conversationId)
        && affectedKeys().hasOnly(['lastMessageAt', 'lastMessageAuthorId'])
        && setsLastMessage();

      match /messages/{messageId} {
        allow read, delete: if isParticipant(conversationId);
        allow create: if isParticipant(conversationId)
          && validMessageCreate()
          && !isBlockedConversation(conversationId);
        allow update: if isParticipant(conversationId)
          && (allowedMessageUpdate()
            || bumpsReplyCounters()
            || (togglesPinnedOnly() && !isBlockedConversation(conversationId)));

        match /replies/{replyId} {
          allow read, delete: if isParticipant(conversationId);
          allow create: if isParticipant(conversationId)
            && validMessageCreate()
            && !isBlockedConversation(conversationId);
          allow update: if isParticipant(conversationId) && allowedMessageUpdate();
        }
      }

      // Co-located per-user read state; readable by either participant so the
      // later receipts pass can read both participants' state in one query.
      match /reads/{uid} {
        allow read: if isParticipant(conversationId);
        allow create, update: if isParticipant(conversationId)
          && request.auth.uid == uid && readDocValid();
      }

      // Co-located per-session typing state (doc id = client session, so two
      // windows of the shared guest account never mute each other). The writer's
      // uid rides inside the doc; a participant may only write their own uid and
      // may only delete a marker that carries it.
      match /typing/{sessionId} {
        allow read: if isParticipant(conversationId);
        allow create, update: if isParticipant(conversationId)
          && typingDocValid()
          && !isBlockedConversation(conversationId);
        allow delete: if isParticipant(conversationId) && (resource == null || resource.data.uid == request.auth.uid);
      }
    }
  }
}
